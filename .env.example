# ============================================================
# .env.example  →  Copy this to .env and fill in real values
# NEVER commit your real .env file to GitHub!
# ============================================================

# PostgreSQL (use Supabase.com for free hosted PostGIS)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/kolo_ride

# Twilio — for WhatsApp messages and SMS driver alerts
# Sign up at: console.twilio.com (free trial available)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WA_NO=whatsapp:+14155238886
TWILIO_SMS_NO=+12015551234

# Campay — Cameroon's MoMo + Orange Money payment gateway
# Sign up at: campay.net
CAMPAY_USER=your_campay_username
CAMPAY_PASS=your_campay_password
CAMPAY_ENV=DEV

# Africa's Talking — USSD gateway
# Sign up at: account.africastalking.com (sandbox is FREE)
AT_API_KEY=your_at_api_key
AT_USERNAME=sandbox
AT_USSD_CODE=*237#

# Flask
SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
PORT=5000
